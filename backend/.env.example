# FinTrack backend — copy to .env and fill in values

# --- OpenAI (optional) ---
# Enables FinBot AI chat. Without this the app still works with a placeholder.
OPENAI_API_KEY=sk-...

# --- Firebase (optional) ---
# Enables Google login and Firestore cloud sync.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Option A — path to the downloaded JSON file:
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/serviceAccountKey.json
#
# Option B — paste the JSON content directly (handy for cloud deployments):
# FIREBASE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account",...}

# --- Demo-only (local mode) ---
# If Firebase auth is NOT configured, the backend can run in a shared default-user mode for localhost demos.
# For safety, this mode is disabled by default and must be explicitly enabled:
DEV_MODE=true

# --- Database (optional) ---
# Defaults to SQLite at backend/fintrack.db. Override for PostgreSQL in production:
# DATABASE_URL=postgresql://user:pass@host/dbname

# --- JWT secret (legacy — not needed when Firebase auth is enabled) ---
# SECRET_KEY=change-me-in-production

# --- TrueLayer bank integration (optional) ---
# Sign up at https://console.truelayer.com, create a Sandbox app, set redirect URI to http://localhost:5174/callback
TRUELAYER_CLIENT_ID=your-client-id
TRUELAYER_CLIENT_SECRET=your-client-secret
TRUELAYER_REDIRECT_URI=http://localhost:5174/callback
