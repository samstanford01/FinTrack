# FinTrack frontend — copy to .env and fill in values
# All VITE_FIREBASE_* values come from:
#   Firebase Console → Project Settings → Your apps → Web app → Config

# Leave blank (or delete this file) to run without Google login.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Optional: override the backend URL (defaults to http://localhost:8000 in prod, /api in dev)
# VITE_API_URL=https://your-backend.railway.app
